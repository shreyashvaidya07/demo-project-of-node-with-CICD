pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                echo 'Installing Dependencies'
                sh 'npm install'
            }
        }

        stage('Test') {
            steps {
                echo 'Running Tests'
                sh 'npm test'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying Application'
                sh 'node app.js &'
            }
        }

    }
}
